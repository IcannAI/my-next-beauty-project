import tracer from 'dd-trace';

const vercelEnv = process.env.VERCEL_ENV || 'development';
const datadogEnv = vercelEnv === 'production' ? 'production' : 
                  vercelEnv === 'preview' ? 'preview' : 
                  'development';

tracer.init({
  env: datadogEnv,
  logInjection: true,
  tracePropagationStyle: ['tracecontext', 'datadog', 'b3'],
  tracePropagationExtract: true,
  tracePropagationInject: true,
  tags: {
    'vercel.env': vercelEnv,
    'vercel.url': process.env.VERCEL_URL || 'n/a',
    'vercel.branch': process.env.VERCEL_GIT_COMMIT_REF || 'n/a',
    'vercel.commit': process.env.VERCEL_GIT_COMMIT_SHA || 'local',
  },
});
