import Image from 'next/image';
import { memo } from 'react';

interface Props {
  avatarUrl?: string | null;
  name?: string | null;
  size?: number;
  priority?: boolean;
}

const Avatar = memo(function Avatar({
  avatarUrl,
  name,
  size = 48,
  priority = false,
}: Props) {
  if (avatarUrl) {
    return (
      <div
        className="rounded-full overflow-hidden flex-shrink-0 bg-gray-100"
        style={{ width: size, height: size }}
      >
        <Image
          src={avatarUrl}
          alt={name || '頭像'}
          width={size}
          height={size}
          className="object-cover w-full h-full"
          priority={priority}
          sizes={`${size}px`}
        />
      </div>
    );
  }

  // Fallback：名字首字母
  const fontSize = size > 64 ? size * 0.35 : size * 0.4;
  return (
    <div
      className="rounded-full bg-rose-500 flex items-center justify-center text-white font-bold flex-shrink-0"
      style={{ width: size, height: size, fontSize }}
    >
      {name?.[0]?.toUpperCase() || '?'}
    </div>
  );
});

export default Avatar;
